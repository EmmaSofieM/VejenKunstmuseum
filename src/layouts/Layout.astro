---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/generel.css';

interface Props {
  title?: string;
}

const { title = 'Vejen Kunstmuseum' } = Astro.props;
---

<!doctype html>
<html lang="da">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100vh;
	}
	
	main {
		min-height: 60vh;
	}
	
	img {
		max-width: 100%;
		height: auto;
	}
</style>
