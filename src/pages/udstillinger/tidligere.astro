---
import Layout from '../../layouts/Layout.astro';
import UdstillingsSlider from '../../components/UdstillingsSlider.astro';

const exhibitions = [
  {
    image: "/udstillinger/julekalender.webp",
    caption: "Julekalenderudstilling 2025",
    color: "#FFE144",
    date: "December 2025 – marts 2026",
    title: "Sophie og det levende slot",
    lead: "Årets julekalenderudstilling er udviklet i samarbejde mellem billedhugger Sophus Ejler Jepsen og musiker Simon Voigt. Udstillingen er målrettet skoleklasser og tilbyder et forløb, hvor eleverne aktivt deltager i en række kreative opgaver fordelt over 24 dage.",
    text: "Med afsæt i fortællingen om Sophie og det levende slot præsenteres en skyggefortælling, hvor motiver fra museets samling indgår i en visuel og lydlig formidling. Forløbet kombinerer fortælling, musik og praktisk arbejde og har en varighed på ca. 60 minutter. Besøget kan suppleres med aktiviteter i museets oplevelsesområder, herunder Ingrid Vang Nymans univers og keramiksamlingen. Udstillingen er gratis for skoler i Vejen Kommune.",
    cta: "Planlæg dit besøg"
  },
  {
    image: "/udstillinger/møbel.webp",
    caption: "Dansk Art Deco – den dekorative modernisme",
    color: "#009C4C",
    date: "Juni 2025 - februar 2026",
    title: "Dansk Art Deco",
    lead: "Udstillingen markerer 100-året for verdensudstillingen i Paris i 1925 og præsenterer en omfattende gennemgang af dansk art deco. Med udgangspunkt i museets nybyggeri fra 2022 vises værker inden for design og anvendt kunst fra perioden mellem de to verdenskrige.",
    text: "Fokus er på den dekorative modernisme, hvor klassiske former kombineres med funktionalismens stramme linjer. Udstillingen inkluderer værker af blandt andre Kai Nielsen, Jean René Gauguin og Jais Nielsen samt tekstile arbejder af Mana og Ebbe Sadolin. Udstillingen belyser samtidig, hvordan art deco prægede arkitektur og byrum, og hvordan mange af periodens værker siden er gledet ud af den brede kunsthistoriske bevidsthed.",
    cta: "Planlæg dit besøg"
  },
  {
    image: "/udstillinger/møbler.webp",
    caption: "Søren Willadsens Møbelfabrik",
    color: "#F73E36",
    date: "Juni 2024 - maj 2025",
    title: "Arkitekttegnede møbler i verdensklasse",
    lead: "Udstillingen sætter fokus på snedkermester Søren Willadsen (1880–1956) og hans betydning for dansk møbelproduktion. Gennem samarbejder med arkitekter som Finn Juhl, Jørgen og Nanna Ditzel samt Illum Wikkelsø blev der produceret møbler, som i dag regnes blandt danske designklassikere.",
    text: "Udstillingen dokumenterer værkstedets rolle i udviklingen af moderne møbeldesign og viser, hvordan produktionen fra Vejen fik både national og international udbredelse.Gennem værker og arkivmateriale tegnes et billede af en central, men ofte overset aktør i dansk designhistorie.",
    cta: "Planlæg dit besøg"
  },   {
    image: "/udstillinger/kreamikmad.webp",
    caption: "Keramiske Food-Processer",
    color: "#FF6443",
    date: "Maj 2025 - januar 2026",
    title: "Keramiske Food-Processer",
    lead: "Udstillingen præsenterer keramiske værker, der tager afsæt i mad som motiv og proces. Gennem eksperimenterende teknikker undersøges lerets muligheder som materiale i arbejdet med form, tekstur og overflade.",
    text: "Værkerne mimer råvarer og anretninger og fremhæver den keramiske proces som en central del af det visuelle udtryk. Fra skæring og modellering til brænding indgår alle trin i skabelsen af værkerne. Udstillingen synliggør det eksperimenterende arbejde i værkstedet og giver indblik i de metoder, der ligger bag færdige kunsthåndværksobjekter.",
    cta: "Planlæg dit besøg"
  },   {
    image: "/udstillinger/auktion.webp",
    caption: "Vejen til kunst",
    color: "#DFFF8C",
    date: "Juni 2024 - maj 2025",
    title: "Vejen til kunst",
    lead: "I forbindelse med museets 100-års jubilæum præsenteres værker af kunstnere med tilknytning til Vejen-egnen. Udstillingen samler forskellige praksisser og medier med afsæt i en lokal forankring.",
    text: "Blandt de deltagende kunstnere er Astrid Dalum, Melanie Zwanikken, Adam Christensen og Anne Mette Schultz. Deres værker spænder fra fotografi til tegning og installation. Udstillingen sætter fokus på forbindelsen mellem det lokale og det kunstneriske arbejde og peger på nye generationer af kunstnere med rødder i området.",
    cta: "Planlæg dit besøg"
  },  
  {
    image: "/udstillinger/trold.webp",
    caption: "Troldske kræfter – danske springvand omkring år 1900",
    color: "#69CB7E",
    date: "September 2023 - april 2024",
    title: "Troldske kræfter – danske springvand omkring år 1900",
    lead: "Udstillingen tager udgangspunkt i Niels Hansen Jacobsens Troldespringvand og sætter det ind i en bredere sammenhæng af dansk vandkunst omkring år 1900.",
    text: "Gennem skitser, modeller og fotografier belyses en periode, hvor springvand spillede en central rolle i byrum og kunstneriske konkurrencer. Udstillingen undersøger både de realiserede værker og de projekter, der aldrig blev opført, og giver indblik i den kunstneriske proces bag dem.",
    cta: "Planlæg dit besøg"
  },
    {
    image: "/udstillinger/ejner.webp",
    caption: "Ejnar Nielsen – Liv & død",
    color: "#FFE144",
    date: "Januar 2023 - August 2023",
    title: "Ejnar Nielsen – Liv & død",
    lead: "UUdstillingen præsenterer maleren Ejnar Nielsen (1872–1956) som en central skikkelse i dansk symbolisme. Med fokus på temaer som liv, død og eksistens skildrer hans værker menneskets vilkår med en monumental enkelhed.",
    text: "Udstillingen tager afsæt i museets omfattende samling af hans værker og viser både malerier og tegninger fra hans tidlige produktion. Dermed gives et samlet indblik i en kunstner, der arbejdede med nogle af de mest grundlæggende spørgsmål i menneskelivet.",
    cta: "Planlæg dit besøg"
  },
    {
    image: "/udstillinger/abstrakt.webp",
    caption: "Maria Wæhrens",
    color: "#E770F1",
    date: "December 2020 - 2021",
    title: "Maria Wæhrens",
    lead: "Udstillingen præsenterer et stedsspecifikt værk af Maria Wæhrens, opbygget direkte i museets rum. Installation og maleri smelter sammen i et visuelt univers, hvor fortælling og form udvikler sig i samspil med omgivelserne.",
    text: "Værket tager afsæt i kunstnerens personlige tilgang til billedskabelse og undersøger forholdet mellem kontrol og spontanitet i processen. Udstillingen åbner et rum for fortolkning, hvor beskueren inviteres til at bevæge sig gennem et sanseligt og fortællende univers.",
    cta: "Planlæg dit besøg"
  }
];
---

<Layout>
    <header class="exhibition-header">
    <h1>
      Tidligere<br>
      udstillinger
    </h1>

    <p>
      Her præsenteres museets tidligere udstillinger.<br>
      Få overblik over, hvad der venter.
    </p>
  </header>
  <UdstillingsSlider
  
    activeTab="tidligere"
    items={exhibitions}
  />
</Layout>

<style>

.exhibition-header {
margin-top: 150px;

  margin-left: 40px;
  margin-bottom: 20px;
}

.exhibition-header h1 {
  max-width: 520px;
  line-height: 0.95;
}

.exhibition-header p {
  margin-top: 10px;
  max-width: 360px;
  font-size: 14px;
  line-height: 1.45;
}
</style>