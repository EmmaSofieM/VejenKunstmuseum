      <img src="/personale/random2.webp" alt="">
      <div class="staff-card__info">
        <p>Museumsassistent</p>
        <h3>Charlotte Kissow Holm</h3>
      </div>
    </article>

    <article class="staff-card staff-card--green">
      <img src="/personale/random3.webp" alt="">
      <div class="staff-card__info">
        <p>Presse og hjemmeside</p>
        <h3>Karen Johanne B. Wichmann</h3>
      </div>
