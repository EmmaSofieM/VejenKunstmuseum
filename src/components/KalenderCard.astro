<style>
.stor {
font-size: 14px;
}
.calendar {
  margin-left: 40px;
  margin-right: 40px;
    margin-bottom: 40px;

  color: #1A1A1A;
  font-family: var(--font-body);
}

.calendar__filter {
  position: relative;
  width: 100%;
  border-bottom: 1px solid #1A1A1A;
}

.calendar__filter-button {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0 0 8px;
  border: 0;
  background: transparent;
  color: inherit;
  font-size: 14px;
  text-transform: uppercase;
  cursor: pointer;
}

.calendar__filter-menu {
  position: absolute;
  top: 100%;
  left: 0;
  display: none;
  min-width: 180px;
  padding: 14px;
  background: #fff;
  border: 1px solid #1A1A1A;
  z-index: 10;
}

.calendar__filter.is-open .calendar__filter-menu {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.calendar__filter-menu button {
  border: 0;
  background: transparent;
  padding: 6px 0;
  color: inherit;
  cursor: pointer;
  font-size: 14px;
}

.calendar__filter-menu button:hover,
.calendar__filter-menu button.is-active {
  text-decoration: underline;
}

.calendar-event {
  border-bottom: 1px solid #1A1A1A;
}

.calendar-event__top {
  width: 100%;
  display: grid;
  grid-template-columns: 120px 120px 130px 1fr 24px;
  gap: 20px;
  align-items: start;
  padding: 10px 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  text-align: left;
  cursor: pointer;
}

.calendar-event__date span,
.calendar-event__top > div {
  font-size: 12px;
  line-height: 1.25;
}

.calendar-event__date {
  display: flex;
  flex-direction: column;
}

.calendar-event__date strong {
  font-size: 16px;
  font-weight: 400;
}

.calendar-event__chevron {
  justify-self: end;
  transition: transform 180ms ease;
}

.calendar-event.is-open .calendar-event__chevron {
  transform: rotate(180deg);
}

.calendar-event__body {
  display: grid;
  grid-template-columns: 190px minmax(0, 1fr);
  gap: 24px;
  max-height: 0;
  overflow: hidden;
  transition: max-height 260ms ease, padding 260ms ease;
}

.calendar-event.is-open .calendar-event__body {
  max-height: 420px;
  padding: 28px 0 54px 180px;
}

.calendar-event__body img {
  width: 190px;
  height: 150px;
  object-fit: cover;
  display: block;
}

.calendar-event__body p {
  margin: 0 0 28px;
  max-width: 720px;
  font-size: 16px;
  line-height: 1.6;
}

.calendar-cta {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  color: inherit;
  font-size: 14px;
  line-height: 1;
  text-decoration: none;
  text-transform: uppercase;
  position: relative;
}

.calendar-cta::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -2px;
  width: 0%;
  height: 1px;
  background: currentColor;
  transition: width 0.2s ease;
}

.calendar-cta:hover::after {
  width: 100%;
}

.calendar-cta img {
  width: 16px;
  height: auto;
  display: block;
}

.calendar-event.is-hidden {
  display: none;
}

