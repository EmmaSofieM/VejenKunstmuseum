<style>
.stor {
font-size: 14px;
}
.calendar {
  margin-left: 40px;
  margin-right: 40px;
    margin-bottom: 40px;

  color: #1A1A1A;
  font-family: var(--font-body);
}

.calendar__filter {
  position: relative;
  width: 100%;
  border-bottom: 1px solid #1A1A1A;
}

.calendar__filter-button {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0 0 8px;
  border: 0;
  background: transparent;
  color: inherit;
  font-size: 14px;
  text-transform: uppercase;
  cursor: pointer;
}

.calendar__filter-menu {
  position: absolute;
  top: 100%;
  left: 0;
  display: none;
  min-width: 180px;
  padding: 14px;
  background: #fff;
  border: 1px solid #1A1A1A;
  z-index: 10;
}

.calendar__filter.is-open .calendar__filter-menu {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.calendar__filter-menu button {
  border: 0;
  background: transparent;
  padding: 6px 0;
  color: inherit;
  cursor: pointer;
  font-size: 14px;
}

.calendar__filter-menu button:hover,
.calendar__filter-menu button.is-active {
  text-decoration: underline;
}

.calendar-event {
  border-bottom: 1px solid #1A1A1A;
}

.calendar-event__top {
  width: 100%;
  display: grid;
  grid-template-columns: 120px 120px 130px 1fr 24px;
  gap: 20px;
  align-items: start;
  padding: 10px 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  text-align: left;
  cursor: pointer;
}

.calendar-event__date span,
.calendar-event__top > div:nth-child(2) {
  font-size: 12px;
  line-height: 1.25;
}

.calendar-event__top > div:nth-child(3),
.calendar-event__top > div:nth-child(4) {
  font-size: 16px;
  line-height: 1.25;
}

.calendar-event__date {
  display: flex;
  flex-direction: column;
}

.calendar-event__date strong {
  font-size: 16px;
  font-weight: 400;
}

.calendar-event__chevron {
  justify-self: end;
  transition: transform 180ms ease;
}
.calendar-event__chevronned {
   transform: rotate(90deg);

}
.calendar-event.is-open .calendar-event__chevron {
  transform: rotate(90deg);
}

.calendar-event__body {
margin-left: 105px;
  display: grid;
  grid-template-columns: 190px minmax(0, 1fr);
  gap: 24px;
  max-height: 0;
  overflow: hidden;
  transition: max-height 260ms ease, padding 260ms ease;
}

.calendar-event.is-open .calendar-event__body {
  max-height: 420px;
  padding: 28px 0 54px 180px;
}

.calendar-event__body img {
  width: 190px;
  height: 150px;
  object-fit: cover;
  display: block;
}

.calendar-event__body p {
  margin: 0 0 28px;
  max-width: 720px;
  font-size: 16px;
  line-height: 1.6;
}

.calendar-cta {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  color: inherit;
  font-size: 14px;
  line-height: 1;
  text-decoration: none;
  text-transform: uppercase;
  position: relative;
}

.calendar-cta::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -2px;
  width: 0%;
  height: 1px;
  background: currentColor;
  transition: width 0.2s ease;
}

.calendar-cta:hover::after {
  width: 100%;
}

.calendar-cta img {
  width: 16px;
  height: auto;
  display: block;
}

.calendar-event.is-hidden {
  display: none;
}

/* FORSIDE VERSION */
.calendar--frontpage .calendar-event:nth-of-type(n+6) {
  display: none;
}

.calendar--frontpage .calendar__filter {
  display: none;
}

@media (max-width: 900px) {
  .calendar {
    margin-left: 16px;
    margin-right: 16px;
    padding: 48px 0 80px;
  }

  .calendar-event__top {
    grid-template-columns: 70px 1fr 24px;
    gap: 12px;
  }

  .calendar-event__top > div:nth-child(2),
  .calendar-event__top > div:nth-child(3) {
    display: none;
  }

  .calendar-event__body,
  .calendar-event.is-open .calendar-event__body {
    grid-template-columns: 1fr;
    padding: 20px 0 40px;
  }

  .calendar-event__body img {
    width: 100%;
    height: auto;
  }
}
</style>

<script>
const filter = document.querySelector(".calendar__filter");
const filterButton = document.querySelector(".calendar__filter-button");
const filterOptions = document.querySelectorAll(".calendar__filter-menu button");
const events = document.querySelectorAll(".calendar-event");
const eventButtons = document.querySelectorAll(".calendar-event__top");
const calendarCtas = document.querySelectorAll(".calendar-cta");

filterButton.addEventListener("click", () => {
  filter.classList.toggle("is-open");
});

eventButtons.forEach((button) => {
  button.addEventListener("click", () => {
    const event = button.closest(".calendar-event");
    event.classList.toggle("is-open");
  });
});

filterOptions.forEach((button) => {
  button.addEventListener("click", () => {
    const selected = button.dataset.filter;

    filterOptions.forEach((item) => item.classList.remove("is-active"));
    button.classList.add("is-active");

    events.forEach((event) => {
      const match = selected === "all" || event.dataset.category === selected;
      event.classList.toggle("is-hidden", !match);
    });

    filter.classList.remove("is-open");
  });
});

document.addEventListener("click", (event) => {
  if (!filter.contains(event.target)) {
    filter.classList.remove("is-open");
  }
});

function escapeICS(value = "") {
  return String(value)
    .replace(/\\/g, "\\\\")
    .replace(/\n/g, "\\n")
    .replace(/,/g, "\\,")
    .replace(/;/g, "\\;");
}

function formatICSDate(value) {
  const date = new Date(value);
  return date.toISOString().replace(/[-:]/g, "").split(".")[0] + "Z";
}

function downloadICS({ title, description, location, start, end }) {
  const fileName = title.toLowerCase().replace(/[^a-z0-9æøå]+/gi, "-").replace(/^-|-$/g, "");

  const icsContent = [
    "BEGIN:VCALENDAR",
    "VERSION:2.0",
    "PRODID:-//Vejen Kunstmuseum//Kalender//DA",
    "BEGIN:VEVENT",
    `UID:${Date.now()}@vejenkunstmuseum.dk`,
    `DTSTAMP:${formatICSDate(new Date())}`,
    `SUMMARY:${escapeICS(title)}`,
    `DESCRIPTION:${escapeICS(description)}`,
    `LOCATION:${escapeICS(location)}`,
    `DTSTART:${formatICSDate(start)}`,
    `DTEND:${formatICSDate(end)}`,
    "END:VEVENT",
    "END:VCALENDAR"
  ].join("\r\n");

  const blob = new Blob([icsContent], { type: "text/calendar;charset=utf-8" });
  const url = URL.createObjectURL(blob);

  const link = document.createElement("a");
  link.href = url;
  link.download = `${fileName || "event"}.ics`;
  document.body.appendChild(link);
  link.click();
  link.remove();

  URL.revokeObjectURL(url);
}

calendarCtas.forEach((cta) => {
  cta.addEventListener("click", (event) => {
    event.preventDefault();

    downloadICS({
      title: cta.dataset.title,
      description: cta.dataset.description,
      location: cta.dataset.location,
      start: cta.dataset.start,
      end: cta.dataset.end
    });
  });
});
</script>