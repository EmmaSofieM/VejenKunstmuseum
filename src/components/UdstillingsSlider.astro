---
import Breadcrumbs from "./Breadcrumbs.astro";

const {
  title = "Kommende udstillinger",
  intro = "Her præsenteres museets aktuelle udstillinger.",
  activeTab = "kommende",
  items = []
} = Astro.props;
---

<section class="exhibition-page">
  

  <Breadcrumbs
    items={[
      { label: "Kommende udstillinger", href: "/udstillinger/kommende", active: activeTab === "kommende" },
      { label: "Aktuelle udstillinger", href: "/udstillinger/aktuelle", active: activeTab === "aktuelle" },
      { label: "Tidligere udstillinger", href: "/udstillinger/tidligere", active: activeTab === "tidligere" }
    ]}
  />

  <div class="exhibition-slider-wrap">
    <div class="exhibition-slider">
      {items.map((item) => (
        <article class="exhibition-slide">
          <figure class="exhibition-image">
            <img src={item.image} alt={item.alt ?? item.title}>
            <figcaption style={`--caption-color: ${item.color ?? "#DFFF8C"}`}>
              {item.caption}
            </figcaption>
          </figure>

            <div class="exhibition-arrows">
  <button class="exhibition-arrow exhibition-arrow--prev" type="button">‹</button>
  <button class="exhibition-arrow exhibition-arrow--next" type="button">›</button>
</div>

      
    </div>

          <div class="exhibition-content">
            <h3 class="exhibition-date">{item.date}</h3>
            <h1>{item.title}</h1>
            <h2 class="exhibition-lead">{item.lead}</h2>
            <p>{item.text}</p>

            {item.cta && (
              <a class="exhibition-cta" href={item.ctaHref ?? "/planlaeg-besoeg"}>
                {item.cta}
                <svg class="exhibition-cta__arrow" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M8 5L16 12L8 19"></path>
                </svg>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

  
  </div>
</section>

<style>

.exhibition-content {
  opacity: 0.60;
  transition: opacity 0.3s ease;
}

.exhibition-slide.is-active .exhibition-content {
  opacity: 1;
}
.exhibition-page {
  margin-bottom: 150px;
  color: #1A1A1A;
  font-family: var(--font-body);
  overflow: hidden;
}

.exhibition-header {
  margin-left: 40px;
  margin-bottom: 20px;
}

.exhibition-header h1 {
  max-width: 520px;
  line-height: 0.95;
}

.exhibition-header p {
  margin-top: 10px;
  max-width: 360px;
  font-size: 14px;
  line-height: 1.45;
}

.exhibition-page :global(.breadcrumbs) {
  margin-left: 40px;
  margin-bottom: 18px;
}

.exhibition-slider-wrap {
  position: relative;
  margin-left: 40px;
}

.exhibition-slider {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: 72vw;
  gap: 8px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  scrollbar-width: none;
}

.exhibition-slider::-webkit-scrollbar {
  display: none;
}

.exhibition-slide {
  scroll-snap-align: start;
  min-width: 0;
}

.exhibition-image {
  margin: 0;
}

.exhibition-image img {
  width: 100%;
  height:70vh;
  object-fit: cover;
  display: block;
}

.exhibition-image figcaption {
  background: var(--caption-color);
  padding: 8px 10px;
  font-size: 20px;
  line-height: 1;
}

.exhibition-arrows {
  display: flex;
  justify-content: flex-end;
  gap: 18px;
  margin-top: 12px;
}

.exhibition-arrow {
  border: 0;
  background: transparent;
  padding: 0;
  color: #1A1A1A;
  font-size: 24px;
  line-height: 1;
  cursor: pointer;
}

.exhibition-arrow:hover {
  text-decoration: underline;
}

.exhibition-content {
  max-width: 760px;
  margin-top: 40px;
}

.exhibition-date {
  margin: 0 0 20px;
  font-size: 12px;
  text-transform: uppercase;
}

.exhibition-content h1 {
  margin: 0 0 20px;
  line-height: 0.95;
  font-weight: bold;
}

.exhibition-content h2 {
  margin: 0 0 20px;
  line-height: 0.95;
  font-weight: 400;
}

.exhibition-content p {
  margin: 0 0 20px;
  font-size: 16px;
  line-height: 1.5;
}

.exhibition-cta {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  margin-top: 90px;
  color: inherit;
  font-size: 14px;
  line-height: 1;
  text-decoration: none;
  text-transform: uppercase;
  position: relative;
}

.exhibition-cta::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -2px;
  width: 0%;
  height: 1px;
  background: currentColor;
  transition: width 0.2s ease;
}

.exhibition-cta:hover::after {
  width: 100%;
}

.exhibition-cta__arrow {
  width: 16px;
  height: auto;
  stroke: currentColor;
  stroke-width: 2;
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
}

@media (max-width: 900px) {
  .exhibition-page {
    margin: 0 16px 80px;
  }

  .exhibition-header {
    margin-left: 0;
  }

  .exhibition-page :global(.breadcrumbs) {
    margin-left: 0;
  }

  .exhibition-slider-wrap {
    margin-left: 0;
  }

  .exhibition-slider {
    grid-auto-columns: 88vw;
  }

  .exhibition-image img {
    height: 42vh;
  }

  .exhibition-arrows {
    width: 88vw;
  }

  .exhibition-content {
    padding: 28px 0 0;
  }
}
</style>

<script>
document.querySelectorAll(".exhibition-slide").forEach((slide) => {
  const slider = slide.closest(".exhibition-slider");
  const prev = slide.querySelector(".exhibition-arrow--prev");
  const next = slide.querySelector(".exhibition-arrow--next");

  function scroll(dir) {
    const amount = slide.offsetWidth + 8;

    slider.scrollBy({
      left: dir * amount,
      behavior: "smooth"
    });
  }

  prev.addEventListener("click", () => scroll(-1));
  next.addEventListener("click", () => scroll(1));
});

const slides = document.querySelectorAll(".exhibition-slide");
const slider = document.querySelector(".exhibition-slider");

function updateActiveSlide() {
  let closestSlide = null;
  let closestOffset = Infinity;

  slides.forEach((slide) => {
    const rect = slide.getBoundingClientRect();
    const offset = Math.abs(rect.left);

    if (offset < closestOffset) {
      closestOffset = offset;
      closestSlide = slide;
    }
  });

  slides.forEach((slide) => {
    slide.classList.toggle("is-active", slide === closestSlide);
  });
}

slider.addEventListener("scroll", () => {
  requestAnimationFrame(updateActiveSlide);
});

updateActiveSlide();
</script>