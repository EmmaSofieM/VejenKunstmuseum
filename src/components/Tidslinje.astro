<style>

    
.wrapper {
  position: relative;
  min-height: 100vh;
  font-family: var(--font-body);
  color: var(--color-text);
}

/* SECTIONS */
.section {
  position: relative;
  height: 100vh;
  width: 100%;
  overflow: hidden;
  padding-bottom: 80px; /* Plads til footer */
}

.section:last-of-type {
  min-height: calc(100vh - 400px);
  height: auto;
}

.section1 { background: #69CB7E; }
.section2 { background: #DFFF8C; }
.section3 { background: #FFE144; }
.section4 { background: #FF6443; }
.section6 { background: #69CB7E; }
.section7 { background: #DFFF8C; }
.section8 { background: #FFE144; }
.section9 { background: #FF6443; }
.section10 { background: #E770F1; }

/* NAV */
.nav__wrapper {
  position: sticky;
  top: 0;
  height: 100vh;
  width: 560px;
  z-index: 20;
  padding: 72px 30px 30px 30px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;

  float: none;        /* vigtigt */
  margin-bottom: -100vh; /* vigtigt */
}

.nav {
  margin: 0 0 40px 30px;
  list-style: none;
  padding: 0;
}

.nav li {
  position: relative;
  margin-bottom: 22px;
}

.nav li::after {
  content: "";
  position: absolute;
  left: -30px;
  top: 15px;
  width: 20px;
  height: 52px;
  border-left: 2px solid var(--color-text);
  border-top: 2px solid var(--color-text);
  opacity: 0.35;
}

.nav li:last-child::after {
  display: none;
}

.nav a {
  display: block;
  color: inherit;
  text-decoration: none;
  transition: padding-left 0.15s ease;
}

.nav a:hover {
  padding-left: 10px;
}

/* YEAR */
.nav__counter {
  display: block;
  font-size: 30px;
  line-height: 1;
  transition: font-size 0.2s ease;
}

/* BODY TEXT */
.nav__body {
  width: 520px;
  max-width: 520px;
  height: 0;
  margin: 0;
  opacity: 0;
  overflow: hidden;
  font-family: var(--font-body);
  font-size: 16px;
  line-height: 1.25;
  transition: opacity 0.25s ease;
}

/* ACTIVE */
.nav li.active {
  padding-left: 10px;
}

.nav li.active::after {
  width: 35px;
  height: 180px;
  top: 35px;
  opacity: 1;
}

.nav li.active .nav__counter {
  font-size: 48px;
}

.nav li.active .nav__body {
  height: auto;
  max-height: 190px;
  margin-top: 14px;
  opacity: 1;
  overflow: visible;
}

/* TIMELINE IMAGES */
.timeline-images {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 5;
}

.timeline-image {
  position: absolute;
  margin: 0;
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.timeline-image img {
  display: block;
  width: 210px;
  height: 115px;
  object-fit: cover;
  filter: grayscale(1);
}

.timeline-image figcaption {
  max-width: 125px;
  font-size: 12px;
  line-height: 1.15;
}

.timeline-image--one {
  left: 31%;
  top: 28%;
}

.timeline-image--two {
  left: 48%;
  top: 53%;
}

.timeline-image--three {
  right: 4%;
