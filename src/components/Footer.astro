---
// filepath: src/components/Footer.astro
---
<footer class="footer">
  <div class="footer-left">
    <div class="footer-top">
      <div class="footer-col">
        <div class="footer-title">MUSEET</div>
        <a href="#">Udstillinger</a>
        <a href="#">Kalender</a>
        <a href="#">Besøg</a>
        <a href="#">Museet</a>
      </div>
      <div class="footer-col">
        <div class="footer-title">PRAKTISK</div>
        <a href="#">Åbningstider</a>
        <a href="#">Priser</a>
        <a href="#">Find vej</a>
      </div>
      <div class="footer-col">
        <div class="footer-title">LEGAL</div>
        <a href="#">Privatlivspolitik</a>
        <a href="#">Undervisning</a>
        <a href="#">Presseomtale</a>
      </div>
    </div>
    <div class="footer-contact">
      <div class="footer-title">KONTAKT</div>
      <div>Vejens Kunstmuseum</div>
      <div>Museumsdirektør, Teresa Nielsen</div>
      <div>6600 Vejen <a href="#">Østergade 4</a></div>
      <div><a href="mailto:museum@vejen.dk">museum@vejen.dk</a></div>
      <div>For presse <a href="mailto:karwi@vejen.dk">karwi@vejen.dk</a></div>
      <div><a href="tel:+4579966942">+45 79 96 69 42</a></div>
      <div class="footer-small">(hverdage 10-16)</div>
      <div class="insta"><a href="https://www.instagram.com/vejenkunstmuseum/" target="_blank"><img src="/ikoner/insta.svg" alt="insta"></a></div>

    </div>
  </div>
  <div class="footer-right">
    <div class="footer-newsletter">
      <div class="footer-title">ABONNER PÅ VORES NYHEDSBREV</div>
      <form class="newsletter">
        <label for="newsletter-email"></label>
        <div class="newsletter-input">
          <input type="email" id="newsletter-email" name="email" placeholder="Email" required />
          <button type="submit" aria-label="Tilmeld">&rsaquo;</button>
        </div>
        <div class="newsletter-check">
          <input type="checkbox" id="accept-privacy" required />
          <label for="accept-privacy">Jeg accepterer <a href="#">privatlivspolitikken</a>.</label>
        </div>
      </form>
    </div>
        <div class="footer-trold"> <img src="/logo/trold.svg" alt="trold"> </div>

    <div class="footer-brand"> <img src="/logo/logorød.svg" alt="logo"> </div>
    </div>
  </div>
</footer>

<style>
.footer {
  display: grid;
  grid-template-columns: 2fr 1fr;
  min-height: 400px;
}
.footer-left {
  background: #E0E1E3;
  padding: 32px 0 0 20px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.footer-top {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 80px;
}
.footer-col {
  display: flex;
  flex-direction: column;
  gap: 8px;
  font-size: 14px;
}
.footer-title {
  font-size: 14px;
  font-weight: light;
  margin-bottom: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.footer-contact {
  margin-top: 40px;
  max-width: 320px;
  font-size: 14px;
  line-height: 1.6;
}
.footer-small {
  font-size: 14px;
}
.footer-right {
  background: #FF6443;
  color: #1A1A1A;
  padding: 16px 16px 40px 20px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
}
.footer-newsletter {
  margin-bottom: 32px;
}
.newsletter {
  margin-top: 20px;
}
.newsletter label {
  font-size: 12px;
}
.newsletter-input {
  display: flex;
  border-bottom: 1px solid #1A1A1A;
  margin-top: 6px;
}
.newsletter-input input {
  flex: 1;
  border: none;
  background: transparent;
  padding: 6px 0;
  font-size: 14px;
  outline: none;
}
.newsletter-input button {
  border: none;
  background: transparent;
  font-size: 20px;
  cursor: pointer;
  color: #1A1A1A;
  padding: 0 8px;
}
.newsletter-check {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 8px;
  font-size: 12px;

}
.newsletter-check a {
  color: #1A1A1A;
  text-decoration: underline;
}
.footer-brand {
  position: absolute;
  bottom: -10px;
  right: 20px;
  z-index: 1;
}
.footer-brand img {
  width: 450px;  
  height: auto;
}

.footer-trold {
  position: absolute;
  bottom: 110px;
  right: 20px;
  z-index: 1;
}
.footer-trold img {
  width: 150px;  
  height: auto;
}
.insta {
  bottom: 16px;
  left: 16px;
padding-top: 20px;}

@media (max-width: 1200px) {
  .footer-brand {
    font-size: 40px;
    right: 20px;
  }
}
@media (max-width: 900px) {
  .footer {
    grid-template-columns: 1fr;
  }
  .footer-left {
    padding: 24px 16px 0 16px;
  }
  .footer-top {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .footer-brand {
    font-size: 24px;
    right: 8px;
    bottom: 8px;
  }
  .footer-right {
    padding: 24px 16px 0 16px;
  }
}
</style>