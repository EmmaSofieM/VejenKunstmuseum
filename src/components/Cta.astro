---
const { href = "#", label = "Læs mere", active = false } = Astro.props;
---

<a href={href} class={`map-cta ${active ? "is-active" : ""}`}>
  {label}
  <svg class="map-cta__arrow" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M8 5L16 12L8 19"></path>
  </svg>
</a>

<style>
.map-cta {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  margin-top: 18px;

  color: inherit;
  font-size: 16px;
  line-height: 1;
  text-decoration: none;
  position: relative;
}

/* underline base */
.map-cta::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -2px;

  width: 0%;
  height: 1px;
  background: currentColor;

  transition: width 0.2s ease;
}

/* hover */
.map-cta:hover::after {
  width: 100%;
}

/* aktiv side (altid streg) */
.map-cta.is-active::after {
  width: 100%;
}

.map-cta__arrow {
  width: 16px;
  height: auto;

  stroke: currentColor;
  stroke-width: 2;
  fill: none;

  stroke-linecap: round;
  stroke-linejoin: round;

  flex-shrink: 0;
}
</style>