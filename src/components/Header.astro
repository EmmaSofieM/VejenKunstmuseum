<script>
  const now = new Date();
  const day = now.getDay();
  const hour = now.getHours();

  const text = document.getElementById("status-text");
  const dot = document.getElementById("status-dot");

  let isOpen = false;

  if (day === 1) {
    isOpen = false;
  } else if (day >= 2 && day <= 5) {
    isOpen = hour >= 10 && hour < 16;
  } else {
    isOpen = hour >= 11 && hour < 17;
  }

  text.textContent = isOpen ? "Åbent" : "Lukket";
  dot.style.background = isOpen ? "#009C4C" : "#F73E36";

  document.querySelectorAll(".dropdown").forEach((dropdown) => {
    const links = dropdown.querySelectorAll(".dropdown__left a");
    const box = dropdown.querySelector(".dropdown__right");
    const title = dropdown.querySelector(".dropdown__right h2");

    links.forEach((link, index) => {
      if (index === 0) {
        link.classList.add("is-active");
        box.style.setProperty("--dropdown-color", link.dataset.color);
        title.textContent = link.dataset.title || link.textContent;
      }

      const activateLink = () => {
        links.forEach((item) => item.classList.remove("is-active"));
        link.classList.add("is-active");

        title.textContent = link.dataset.title || link.textContent;
        box.style.setProperty("--dropdown-color", link.dataset.color || "#D9FF72");
      };

      link.addEventListener("mouseenter", activateLink);
      link.addEventListener("focus", activateLink);
    });
  });
</script>

