<style>

    .collection-card {
  display: block;
  text-decoration: none;
  color: inherit;
}

.collection-card:hover {
  opacity: 0.9;
}
    .collection-card__meta {
  margin-top: 65px;
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 16px;
  font-size: 12px;
  line-height: 1.15;
}
.collection-front {
  margin: 0 40px 80px;
  color: #1A1A1A;
  font-family: var(--font-body);
}

.collection-front__top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25px;
    margin-top: 100px;

}

.collection-front__top h2 {
  margin: 0;
}

.collection-front__arrows {
  display: flex;
  gap: 18px;
}

.collection-front__arrow {
  border: 0;
  background: transparent;
  padding: 0;
  font-size: 24px;
  cursor: pointer;
}

.collection-front__slider {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: calc((100% - 16px) / 3);
  gap: 8px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  scrollbar-width: none;
}

.collection-front__slider::-webkit-scrollbar {
  display: none;
}

.collection-card {
  scroll-snap-align: start;
  background: #DFFF8C;
  min-width: 0;
}

.collection-card img {
  width: 100%;
  aspect-ratio: 1 / 0.72;
  object-fit: cover;
  display: block;
}

.collection-card__content {
  min-height: 145px;
  padding: 10px 12px 12px;
}

.collection-card__artist {
  margin: 0 0 5px;
  font-size: 10px;
  line-height: 1.15;
  text-transform: uppercase;
}

.collection-card h3 {
  margin: 0;
  font-size: 14px;
  line-height: 1.15;
  font-weight: 400;
}

@media (max-width: 900px) {
  .collection-front {
    margin: 0 16px 60px;
  }

  .collection-front__slider {
    grid-auto-columns: 82%;
  }
}
</style>

<script>
const collectionFrontSlider = document.querySelector(".collection-front__slider");
const collectionFrontPrev = document.querySelector(".collection-front__arrow--prev");
const collectionFrontNext = document.querySelector(".collection-front__arrow--next");

function scrollCollectionFront(direction) {
  const card = collectionFrontSlider.querySelector(".collection-card");
  const gap = 8;
  const amount = card.offsetWidth + gap;

  collectionFrontSlider.scrollBy({
    left: direction * amount,
    behavior: "smooth"
  });
}

collectionFrontPrev.addEventListener("click", () => scrollCollectionFront(-1));
collectionFrontNext.addEventListener("click", () => scrollCollectionFront(1));
</script>